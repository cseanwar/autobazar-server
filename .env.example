# Server
PORT=5000

# Authentication
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:5000
# For production, set to your deployed server URL:
# BETTER_AUTH_URL=https://autobazar-server.vercel.app

# Allowed CORS origins (comma-separated for multiple origins)
CLIENT_URL=http://localhost:3000
# For production, add your Vercel frontend URL:
# CLIENT_URL=http://localhost:3000,https://autobazar-client.vercel.app

# Database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster
DB_NAME=autobazaar_db

# AI (optional — features gracefully handle missing key)
# Note: Groq may geo-block certain IPs. Use a VPN or US/EU Vercel region.
GROQ_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
